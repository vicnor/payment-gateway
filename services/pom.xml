  </parent>

  <artifactId>payment-gateway-services</artifactId>
  <packaging>pom</packaging>

  <name>Payment Gateway — Services</name>
  <description>Aggregator for independently deployable services</description>

  <modules>
    <!-- Populated as services are built (Phase 1+):
         checkout-service, token-service, payment-service,
         webhook-service, merchant-service, test-acquirer-service -->
  </modules>

  <!--
    ADR-0002: When services are added as modules, activate the maven-enforcer-plugin
    bannedDependencies rule here to prevent cross-service compile dependencies
    (ban com.gateway.<service>:* from depending on another com.gateway.<service>:*).
    Cross-service communication must go through HTTP or SNS/SQS events only.
  -->

